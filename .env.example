# Pollinations API Configuration
# Get your API key from: https://enter.pollinations.ai

# Base URL for Pollinations API (default: https://gen.pollinations.ai)
NEXT_PUBLIC_POLLINATIONS_API_URL=https://gen.pollinations.ai

# Media storage URL for image uploads
NEXT_PUBLIC_POLLINATIONS_MEDIA_URL=https://media.pollinations.ai

# Optional: Enable debug logging (set to 'true' for development)
NEXT_PUBLIC_DEBUG_MODE=false

# Optional: Vercel Analytics (enabled by default if @vercel/analytics is installed)
NEXT_PUBLIC_VERCEL_ANALYTICS_ENABLED=true

# Optional: Rate limiting configuration (requests per minute)
NEXT_PUBLIC_RATE_LIMIT_REQUESTS=60

# Optional: Cache TTL in milliseconds (default: 5 minutes)
NEXT_PUBLIC_CACHE_TTL=300000

# Optional: Maximum history items to store in localStorage
NEXT_PUBLIC_MAX_HISTORY_ITEMS=300

# Optional: Maximum batch size for image generation
NEXT_PUBLIC_MAX_BATCH_SIZE=10

# Optional: Maximum reference images for editing
NEXT_PUBLIC_MAX_REFERENCE_IMAGES=4

# Optional: Application URL for BYOP OAuth redirect
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional: Sentry DSN for error tracking (if using Sentry)
# NEXT_PUBLIC_SENTRY_DSN=

# Optional: PostHog API key for analytics (if using PostHog)
# NEXT_PUBLIC_POSTHOG_KEY=
